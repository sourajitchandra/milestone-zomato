# Hugging Face dataset
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# Groq API — get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=1024

# Recommendation tuning
MAX_CANDIDATES=50
DEFAULT_TOP_N=5

# Budget tier thresholds (cost for two, in local currency — tune after inspecting dataset)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500
